# Copy this file to .env and fill in the values you need.
# Only DATABASE_URL is required to start the server — everything else is
# optional and falls back to safe defaults (see config/index.ts).

# PostgreSQL connection string (required)
DATABASE_URL="postgresql://user:password@localhost:5432/ai_influencer"

# Server
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# Instagram Graph API (optional — only needed for real publishing via
# src/services/instagramService.ts; requires a Business/Creator account and
# Meta App Review, see README.md)
IG_APP_ID=
IG_APP_SECRET=
IG_ACCESS_TOKEN=
IG_BUSINESS_ACCOUNT_ID=

# Image/video generation (optional — defaults to "local-stub", which writes
# placeholder files with no external API calls or cost)
IMAGE_GEN_API_KEY=
VIDEO_GEN_API_KEY=
# Kling AI uses a signed JWT (access/secret key pair) instead of a plain
# bearer token — only needed when VIDEO_GEN_PROVIDER=kling
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
# IMAGE_GEN_PROVIDER: local-stub | stability | nano-banana
IMAGE_GEN_PROVIDER=local-stub
# VIDEO_GEN_PROVIDER: local-stub | seedance | kling
VIDEO_GEN_PROVIDER=local-stub

# Face-swap post-processing (optional) — runs after image generation and
# replaces the generated face with the character's exact reference-photo
# face, since Gemini's reference-image conditioning alone isn't a strict
# identity guarantee. Off by default (extra paid API call).
FACE_SWAP_API_KEY=
# FACE_SWAP_PROVIDER: none | replicate | piapi
FACE_SWAP_PROVIDER=none

# Fanvue (optional)
FANVUE_ACCOUNT_EMAIL=
FANVUE_PROFILE_URL=

# Analytics webhook (optional)
ANALYTICS_WEBHOOK_SECRET=
