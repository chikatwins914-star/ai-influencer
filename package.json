{
  "name": "ai-influencer",
  "version": "0.1.0",
  "private": true,
  "description": "AI influencer content operations system (character mgmt, prompt generation, calendar, analytics, Fanvue/UGC CRM)",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "prisma migrate deploy --schema=database/schema.prisma && node dist/src/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "content:generate-today": "tsx scripts/generateDailyContent.ts",
    "calendar:generate": "tsx scripts/generateCalendar.ts",
    "analytics:weekly-report": "tsx scripts/generateWeeklyReport.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"shared/**/*.ts\""
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "multer": "^2.2.0",
    "pino": "^9.4.0",
    "playwright": "^1.47.0",
    "replicate": "^1.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.7.0",
    "eslint": "^9.11.1",
    "pino-pretty": "^11.2.2",
    "prettier": "^3.3.3",
    "prisma": "^5.20.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.7.0",
    "vitest": "^2.1.1"
  }
}
